#include <iostream>
#include <string>
using namespace std;

class Quest {
private:
    string title;
    int maxParticipants;
    int level;
    double cost;

public:
    Quest() {
        title = "Новый квест";
        maxParticipants = 1;
        level = 1;
        cost = 1000;
        cout << "> Создан пустой квест" << endl;
    }
    
    Quest(string name, int participants, int difficulty, double price) {
        title = name;
        
        if (participants > 0) {
            maxParticipants = participants;
        } else {
            maxParticipants = 1;
            cout << "> Предупреждение: участников должно быть > 0, установлено 1" << endl;
        }
        
        if (difficulty >= 1 && difficulty <= 5) {
            level = difficulty;
        } else {
            level = 1;
            cout << "> Предупреждение: сложность должна быть 1-5, установлена 1" << endl;
        }
        
        if (price > 0) {
            cost = price;
        } else {
            cost = 1000;
            cout << "> Предупреждение: цена должна быть > 0, установлена 1000" << endl;
        }
        
        cout << "> Квест \"" << title << "\" готов к работе!" << endl;
    }
    
    ~Quest() {
        cout << "> Квест \"" << title << "\" завершен и закрыт" << endl;
    }
    
    string getTitle() { 
        return title; 
    }
    
    int getMaxParticipants() { 
        return maxParticipants; 
    }
    
    int getLevel() { 
        return level; 
    }
    
    double getCost() { 
        return cost; 
    }
    
    void changeDifficulty(int newLevel) {
        if (newLevel >= 1 && newLevel <= 5) {
            level = newLevel;
            cout << "> Сложность квеста изменена на " << newLevel << endl;
        } else {
            cout << "> Нельзя установить сложность " << newLevel << "! Можно только 1, 2, 3, 4 или 5" << endl;
        }
    }
    
    void updatePrice(double newPrice) {
        if (newPrice > 0) {
            cost = newPrice;
            cout << "> Цена квеста теперь " << newPrice << " руб." << endl;
        } else {
            cout << "> Цена должна быть положительной! Значение " << newPrice << " не подходит" << endl;
        }
    }
    
    void bookTeam(int teamSize) {
        cout << "> Попытка забронировать квест для " << teamSize << " человек: ";
        
        if (teamSize <= 0) {
            cout << "нельзя бронировать для 0 или меньше человек" << endl;
        } else if (teamSize > maxParticipants) {
            cout << "нужно больше мест! Максимум можно " << maxParticipants << endl;
        } else {
            cout << "ГОТОВО! Команда записана на квест" << endl;
        }
    }
    
    double priceWithDifficulty() {
        double multiplier = 1.0 + (level - 1) * 0.2;
        double finalPrice = cost * multiplier;
        cout << "> Базовая цена: " << cost << " руб., коэф. сложности: " << multiplier;
        cout << ", итого: " << finalPrice << " руб." << endl;
        return finalPrice;
    }
    
    void showInfo() {
        cout << "\n========== ИНФОРМАЦИЯ О КВЕСТЕ ==========" << endl;
        cout << "Название: " << title << endl;
        cout << "Вместимость: " << maxParticipants << " человек" << endl;
        cout << "Уровень сложности: " << level << "/5" << endl;
        cout << "Стоимость: " << cost << " руб." << endl;
        cout << "Итоговая цена (с учётом сложности): " << priceWithDifficulty() << " руб." << endl;
        cout << "==========================================\n" << endl;
    }
};

int main() {
    setlocale(LC_ALL, "Russian");
    
    cout << "=============================================" << endl;
    cout << "   ПРАКТИЧЕСКАЯ РАБОТА: ОРГАНИЗАЦИЯ КВЕСТОВ   " << endl;
    cout << "=============================================\n" << endl;
    
    cout << "--- СОЗДАЁМ КВЕСТЫ ---" << endl;
    Quest emptyQuest;
    Quest adventureQuest("Побег из комнаты", 5, 3, 2500);
    Quest horrorQuest("Тайна старого дома", 4, 5, 3500);
    
    cout << "\n--- ПРОВЕРЯЕМ ДАННЫЕ ЧЕРЕЗ ГЕТТЕРЫ ---" << endl;
    cout << "Название: " << adventureQuest.getTitle() << endl;
    cout << "Вместимость: " << adventureQuest.getMaxParticipants() << " человек" << endl;
    cout << "Сложность: " << adventureQuest.getLevel() << endl;
    cout << "Цена: " << adventureQuest.getCost() << " руб." << endl;
    
    cout << "\n--- МЕНЯЕМ ПАРАМЕТРЫ ЧЕРЕЗ СЕТТЕРЫ ---" << endl;
    cout << "Пробуем изменить сложность:" << endl;
    adventureQuest.changeDifficulty(4);
    adventureQuest.changeDifficulty(10);
    
    cout << "\nПробуем изменить цену:" << endl;
    adventureQuest.updatePrice(3000);
    adventureQuest.updatePrice(-500);
    
    cout << "\n--- РАБОТАЕМ С БРОНИРОВАНИЕМ ---" << endl;
    adventureQuest.bookTeam(3);
    adventureQuest.bookTeam(6);
    adventureQuest.bookTeam(-2);
    
    cout << "\n--- СЧИТАЕМ ЦЕНУ СО СЛОЖНОСТЬЮ ---" << endl;
    cout << "Квест \"" << adventureQuest.getTitle() << "\": ";
    adventureQuest.priceWithDifficulty();
    cout << "Квест \"" << horrorQuest.getTitle() << "\": ";
    horrorQuest.priceWithDifficulty();
    
    cout << "\n--- ВЫВОДИМ ПОЛНУЮ ИНФОРМАЦИЮ ---" << endl;
    adventureQuest.showInfo();
    horrorQuest.showInfo();
    emptyQuest.showInfo();
    
    cout << "\n--- ТЕСТ НА ЗАЩИТУ ОТ ГЛУПОСТЕЙ ---" << endl;
    cout << "Создаём квест с неправильными данными:" << endl;
    Quest stupidQuest("Сломанный квест", -10, 10, -2000);
    stupidQuest.showInfo();
    
    cout << "\n--- ВСЁ! ПРОГРАММА ЗАВЕРШЕНА ---" << endl;
    cout << "Сейчас все объекты автоматически удалятся\n" << endl;
    
    return 0;
}
